{
  "version": 2,
  "builds": [
    {
      "src": "src/app.py",
      "use": "@vercel/python@3.9"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/app.py"
    }
  ]
}
